# Load environment variables from .env if it exists
if [ -f .env ]; then
  dotenv .env
fi

# Load devbox environment
eval "$(devbox generate direnv --print-envrc)"

# Decrypt talos configs if sops key is available
if [ -f ~/.config/sops/age/keys.txt ]; then
  sops -d talos/kubeconfig > /tmp/kubeconfig 2>/dev/null && export KUBECONFIG=/tmp/kubeconfig
  sops -d talos/talosconfig > /tmp/talosconfig 2>/dev/null && export TALOSCONFIG=/tmp/talosconfig
fi
