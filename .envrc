# Load environment variables from .env if it exists
if [ -f .env ]; then
  dotenv .env
fi

# Load devbox environment
eval "$(devbox generate direnv --print-envrc)"

# Decrypt talos configs if sops key is available
if [ -f ~/.config/sops/age/keys.txt ]; then
  SECRETS_DIR="${XDG_RUNTIME_DIR:-$HOME/.cache}/homelab-secrets"
  mkdir -p "$SECRETS_DIR" && chmod 700 "$SECRETS_DIR"
  sops -d talos/kubeconfig 2>/dev/null | sed 's|kube.lab-01.local|91.99.132.65|g' > "$SECRETS_DIR/kubeconfig" && export KUBECONFIG="$SECRETS_DIR/kubeconfig"
  sops -d talos/talosconfig > "$SECRETS_DIR/talosconfig" 2>/dev/null && export TALOSCONFIG="$SECRETS_DIR/talosconfig"
fi
