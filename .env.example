# AWS Configuration (for S3 backend with native locking)
# Set your AWS SSO profile name (e.g., AdministratorAccess-123456789012)
AWS_PROFILE=your-aws-sso-profile-name
# eu-central-1 (Frankfurt) is closest to Hetzner nbg1 (Nuremberg)
AWS_REGION=eu-central-1
TF_STATE_BUCKET=your-terraform-state-bucket-name

# Hetzner Cloud API Token (REQUIRED!)
# Get your token from: https://console.hetzner.cloud/ > Projects > Security > API Tokens
HCLOUD_TOKEN=your-hetzner-cloud-api-token-here
